{
  "$description": "Finding gap 디자인 토큰 (단일 소스). W3C Design Tokens 형식 — 코드(tokens.css/tailwind.preset)·Figma Variables 양쪽으로 사용.",
  "color": {
    "redlist": {
      "$description": "국가적색목록 평가범주 (IUCN 표준색)",
      "ex": { "$type": "color", "$value": "#000000", "$description": "절멸 Extinct" },
      "ew": { "$type": "color", "$value": "#3D2645", "$description": "야생절멸 Extinct in the Wild" },
      "re": { "$type": "color", "$value": "#6B4E71", "$description": "지역절멸 Regionally Extinct" },
      "cr": { "$type": "color", "$value": "#D81E05", "$description": "위급 Critically Endangered" },
      "en": { "$type": "color", "$value": "#FC7F3F", "$description": "위기 Endangered" },
      "vu": { "$type": "color", "$value": "#F2DC00", "$description": "취약 Vulnerable" },
      "nt": { "$type": "color", "$value": "#C3D838", "$description": "준위협 Near Threatened" },
      "lc": { "$type": "color", "$value": "#5CB85C", "$description": "최소관심 Least Concern" },
      "dd": { "$type": "color", "$value": "#CFCFC4", "$description": "정보부족 Data Deficient" },
      "na": { "$type": "color", "$value": "#EAEAE2", "$description": "미적용 Not Applicable" },
      "ne": { "$type": "color", "$value": "#F7F7F4", "$description": "미평가 Not Evaluated" }
    },
    "endangered": {
      "$description": "멸종위기 야생생물 등급",
      "level1": { "$type": "color", "$value": "#7F1D1D", "$description": "멸종위기 I급" },
      "level2": { "$type": "color", "$value": "#C2410C", "$description": "멸종위기 II급" }
    },
    "taxon": {
      "$description": "관리분류군 1~11 카테고리 색",
      "mammal":          { "$type": "color", "$value": "#8B5E3C", "$description": "포유류 MM" },
      "bird":            { "$type": "color", "$value": "#2F6FB0", "$description": "조류 AV" },
      "reptile":         { "$type": "color", "$value": "#4F8F3F", "$description": "파충류 RP" },
      "amphibian":       { "$type": "color", "$value": "#3FA796", "$description": "양서류 AM" },
      "fish":            { "$type": "color", "$value": "#2C7BA6", "$description": "어류 -P" },
      "tunicate":        { "$type": "color", "$value": "#9C6FB0", "$description": "미삭동물 UC" },
      "cephalochordate": { "$type": "color", "$value": "#B07FA0", "$description": "두삭동물 CC" },
      "invertebrate":    { "$type": "color", "$value": "#C2667A", "$description": "무척추동물(곤충제외) IV" },
      "insect":          { "$type": "color", "$value": "#D98C36", "$description": "곤충류 IN" },
      "vascular":        { "$type": "color", "$value": "#5C9A3A", "$description": "관속식물 VP" },
      "bryophyte":       { "$type": "color", "$value": "#7FA05C", "$description": "선태류 MS" }
    }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "6px" },
    "md": { "$type": "dimension", "$value": "8px" },
    "lg": { "$type": "dimension", "$value": "12px" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "6": { "$type": "dimension", "$value": "24px" }
  }
}
