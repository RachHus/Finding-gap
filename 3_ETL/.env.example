# 3_ETL 환경변수 템플릿 — 실제 값은 .env 에 넣으세요 (.env 는 git 제외됨)
# 복사: cp .env.example .env  후 값 채우기

# ── NIBR 국가생물종목록 API ──
NIBR_API_KEY=YOUR_oapiAcsUnqNo          # 인증키(oapiAcsUnqNo) — 허용 IP 등록 필요

# ── GBIF (선택: 대량 다운로드 시) ──
GBIF_USER=YOUR_GBIF_USER
GBIF_PWD=YOUR_GBIF_PASSWORD
GBIF_EMAIL=YOUR_GBIF_EMAIL

# ── EcoBank API ──
ECOBANK_API_KEY=YOUR_ECOBANK_KEY

# ── Supabase 적재용(서버 전용 키) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
